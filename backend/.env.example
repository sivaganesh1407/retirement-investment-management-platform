# Copy to .env and set values. Do not commit .env to version control.
# Generate a JWT secret: openssl rand -hex 32
JWT_SECRET=replace_with_at_least_32_bytes_hex_or_use_openssl_rand_hex_32

# Optional: use PostgreSQL (e.g. with docker-compose postgres service)
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/financial_platform
# SPRING_DATASOURCE_USERNAME=app
# SPRING_DATASOURCE_PASSWORD=app
